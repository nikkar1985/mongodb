ΤΑΞΙΝΟΜΗΣΗ ΧΡΗΣΤΩΝ ΑΠΟ ΜΕΓΑΛΥΤΕΡΟ ΣΕ ΜΙΚΡΟΤΕΡΟ

ΒΗΜΑ 1
ΝΑ ΒΡΟΥΜΕ ΠΟΥ ΣΕ ΠΟΙΑ ΚΑΤΗΓΟΡΙΑ ΑΝΗΚΟΥΝ ΟΙ ΧΡΗΣΤΕΣ

db.collection.aggregate([
  {
    "$match": {
      "type": "profile"
    }
  }
])

ΒΗΜΑ 2 
ΤΑΞΙΝΟΜΗΣΗ = SORT
ΑΠΟ ΜΕΓΑΛΥΤΕΡΟ ΣΕ ΜΙΚΡΟΤΕΡΟ ΣΗΜΑΙΝΕΙ - 1

db.collection.aggregate([
  {
    "$match": {
      "type": "profile"
    }
  },
  {
    "$sort": {
      "age": -1
    }
  }
])

ΑΥΤΟ ΣΗΜΑΙΝΕΙ ΑΠΟ ΜΙΚΡΟΤΕΡΟ ΣΕ ΜΕΓΑΛΥΤΕΡΟ
db.collection.aggregate([
  {
    "$match": {
      "type": "profile"
