  });

  const User = mongoose.model("User", userSchema);

  // 3. ΔΗΜΙΟΥΡΓΙΑ ΕΓΓΡΑΦΩΝ
  await User.create([
    { fullname: "Ελένη Κώστα", age: 20, city: "Athens", isStudent: true },
