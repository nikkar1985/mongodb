  const uri = mongo.getUri();

  // Σύνδεση στη βάση
  await mongoose.connect(uri);
  console.log("✅ Συνδεθήκαμε στη MongoDB!");

  // --- 2. ΤΟ ΣΧΗΜΑ (SCHEMA) ---
  // Εδώ ορίζουμε τους κανόνες: Τι στοιχεία θα έχει ένας Χρήστης;
