const mongoose = require('mongoose');
const { MongoMemoryServer } = require('mongodb-memory-server');

async function run() {
  // --- 1. ΡΥΘΜΙΣΗ ΒΑΣΗΣ (Η "ΑΠΟΘΗΚΗ" ΜΑΣ) ---
  // Δημιουργούμε μια εικονική βάση στη μνήμη (RAM)
  const mongo = await MongoMemoryServer.create();
  const uri = mongo.getUri();

  // Σύνδεση στη βάση
  await mongoose.connect(uri);
  console.log("✅ Συνδεθήκαμε στη MongoDB!");

  // --- 2. ΤΟ ΣΧΗΜΑ (SCHEMA) ---
  // Εδώ ορίζουμε τους κανόνες: Τι στοιχεία θα έχει ένας Χρήστης;
  const userSchema = new mongoose.Schema({
    fullname: String,
    age: Number,
    isStudent: Boolean
  });

  // Μετατρέπουμε το Σχήμα σε "Μοντέλο" για να μπορούμε να το χρησιμοποιήσουμε
  const User = mongoose.model('User', userSchema);

  // --- 3. ΔΗΜΙΟΥΡΓΙΑ ΕΓΓΡΑΦΗΣ (DOCUMENT) ---
  // Φτιάχνουμε έναν συγκεκριμένο χρήστη
  const student = new User({
    fullname: "Μαρία Παπαδοπούλου",
    age: 21,
    isStudent: true
  });

  // Τον σώζουμε στη βάση (αυτό είναι το "Create" στο CRUD)
  await student.save();
  console.log("💾 Ο χρήστης αποθηκεύτηκε με επιτυχία!");

  // --- 4. ΑΝΑΓΝΩΣΗ (READ) ---
  // Ζητάμε από τη βάση να μας δείξει όλους τους χρήστες που βρήκε
  const allUsers = await User.find();
 
  console.log("🔍 Λίστα χρηστών στη βάση:");
  console.log(allUsers);
}

// Εκτέλεση της συνάρτησης
run().catch(err => console.error("❌ Σφάλμα:", err));



