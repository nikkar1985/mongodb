db.collection.aggregate([
  {
    "$match": {
      "status": "active",
      "balance": {
        "$gte": 500
      }
    }
  },
  {
    "$sort": {
      "balance": -1
    }
  },
  {
    "$project": {
      "name": 1,
      "city": 1,
      "balance": 1,
      "_id": 0
    }
  }
])

