ΔΗΜΙΟΥΡΓΙΑ ΜΟΝΟ ΕΝΟΣ ΝΕΟ ΠΕΔΙΟΥ


db.collection.aggregate([
  {
    "$addFields": {
      "risk_level": {
        "$cond": {
          "if": {
            "$lt": [
              "$balance",
              500
            ]
          },
          "then": "HIGH",
          "else": "LOW"
        }
      }
    }
  }
])

